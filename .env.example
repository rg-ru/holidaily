# Server
PORT=3000
NODE_ENV=development
TRUST_PROXY=false

# Security
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars
ADMIN_SESSION_TTL_HOURS=12

# Dedicated support chat database
CHAT_DB_PATH=./data/chat-support.sqlite

# Single admin
ADMIN_EMAIL=support@holidaily.local
ADMIN_NAME=Support Admin
ADMIN_PASSWORD=ChangeMe-Strong-123!

# Optional production variant:
# ADMIN_PASSWORD_HASH=$2a$12$replace_with_bcrypt_hash

# Optional multi-admin setup:
# ADMIN_USERS_JSON=[{"email":"support@holidaily.local","name":"Support Admin","password":"ChangeMe-Strong-123!"}]
